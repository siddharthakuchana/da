import pandas as pd
from sklearn.linear_model import LinearRegression

data = {
  'X':  [1,2,3,4,5],
  'Y': [2,4,5,4,5]
}

df=pd.DataFrame(data)
X=df[['X']]
y= df['Y']

model=LinearRegression()
model.fit(X,y)
print("slope: ",model.coef_)
print("intercept: ",model.intercept_)

print("predicted Value:" , model.predict([[6]]))
